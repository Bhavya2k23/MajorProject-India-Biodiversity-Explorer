# =============================================================================
# India Biodiversity Explorer - Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?options
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/biodiversity_db?retryWrites=true&w=majority

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_characters
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no spaces)
# Production: your actual domain(s)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ─── External API Keys (Optional) ─────────────────────────────────────────────
# IUCN Red List API - get token at https://apiv3.iucnredlist.org/api/v3/token
IUCN_API_TOKEN=

# GBIF API - free, no token required for limited use
# GBIF_API_KEY=

# ─── AI Service Configuration ─────────────────────────────────────────────────
# URL of the Python FastAPI image recognition service
# Start AI service: cd backend/ai_service && pip install -r requirements.txt && python main.py
AI_SERVICE_URL=http://localhost:8000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Number of requests allowed per 15-minute window per IP
RATE_LIMIT_MAX=100

# ─── Cache Configuration ───────────────────────────────────────────────────────
# MongoDB cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300
