PORT=5001
NODE_ENV=development

MONGO_URI=mongodb+srv://biodiversityUser:Biodiversity123@cluster0.9fjypkc.mongodb.net/biodiversity_db?retryWrites=true&w=majority

JWT_SECRET=biodiversity_super_secret_key
JWT_EXPIRES_IN=7d

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081

# External API Keys (optional - features work without them using fallback data)
IUCN_API_TOKEN=

# ─── Image Service API Keys ─────────────────────────────────────
# Unsplash API - Primary image source (https://unsplash.com/developers)
# Get your key at: https://unsplash.com/developers
# If not set, falls back to Pexels → Wikimedia → local backup → static fallback
UNSPLASH_ACCESS_KEY=

# Pexels API - Secondary image source (https://www.pexels.com/api/)
# Get your key at: https://www.pexels.com/api/
# If not set, falls back to Wikimedia → local backup → static fallback
PEXELS_API_KEY=

# ─── AI Service Configuration ─────────────────────────────────────────────
# Python FastAPI AI service URL for image recognition
AI_SERVICE_URL=http://localhost:8000
# AI Service startup: cd backend/ai_service && pip install -r requirements.txt && python main.py
